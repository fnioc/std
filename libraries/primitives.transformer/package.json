{
  "name": "@rhombus-std/primitives.transformer",
  "version": "10.1.0",
  "description": "The standalone token-derivation authoring transformer: the nameof<T>() compile-time token mechanism plus the inline and signatureof primitive stages. A Go/ttsc descriptor package — the derivation runs in the shared owner binary, di-independent so any family can mint augmentation tokens from types.",
  "keywords": [
    "primitives",
    "typescript",
    "transformer",
    "compiler",
    "nameof"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/primitives.transformer"
  },
  "type": "module",
  "main": "./dist/bundle/index.js",
  "types": "./dist/bundle/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./dist/bundle/index.js",
      "types": "./dist/bundle/index.d.ts",
      "import": "./dist/bundle/index.js",
      "default": "./dist/bundle/index.js"
    },
    "./ttsc": "./ttsc.mjs",
    "./inline-ttsc": "./ttsc-inline.mjs",
    "./signatureof-ttsc": "./ttsc-signatureof.mjs",
    "./keyof-ttsc": "./ttsc-keyof.mjs"
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/primitives.transformer/ttsc"
    },
    "stages": ["inline", "nameof", "signatureof", "keyof", "mergesynth"]
  },
  "files": [
    "dist",
    "ttsc.mjs",
    "ttsc-inline.mjs",
    "ttsc-signatureof.mjs",
    "ttsc-keyof.mjs"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.ci.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/bundle/index.js",
    "types": "./dist/bundle/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/bundle/index.d.ts",
        "import": "./dist/bundle/index.js",
        "default": "./dist/bundle/index.js"
      },
      "./ttsc": "./ttsc.mjs",
      "./inline-ttsc": "./ttsc-inline.mjs",
      "./signatureof-ttsc": "./ttsc-signatureof.mjs",
      "./keyof-ttsc": "./ttsc-keyof.mjs"
    }
  }
}
