{
  "name": "@rhombus-std/primitives.transformer",
  "version": "10.1.0",
  "description": "The standalone token-derivation ts-patch transformer: the nameof<T>() compile-time token mechanism and the token-generation machinery, di-independent so any family can mint augmentation tokens from types.",
  "keywords": [
    "primitives",
    "typescript",
    "ts-patch",
    "transformer",
    "compiler",
    "nameof"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/primitives.transformer"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ttsc": "./ttsc.mjs",
    "./inline-ttsc": "./ttsc-inline.mjs",
    "./signatureof-ttsc": "./ttsc-signatureof.mjs",
    "./_/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/primitives.transformer/ttsc"
    }
  },
  "files": [
    "dist",
    "ttsc.mjs",
    "ttsc-inline.mjs",
    "ttsc-signatureof.mjs"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "3.5.3"
  },
  "peerDependencies": {
    "typescript": ">=5.2"
  },
  "devDependencies": {
    "ts-patch": "^3.3.0",
    "ttsc": "^0.18.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./ttsc": "./ttsc.mjs",
      "./inline-ttsc": "./ttsc-inline.mjs",
      "./signatureof-ttsc": "./ttsc-signatureof.mjs"
    }
  }
}
