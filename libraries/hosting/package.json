{
  "name": "@rhombus-std/hosting",
  "version": "0.0.0",
  "description": "The Generic Host runtime: HostBuilder / HostApplicationBuilder, the static Host factory, HostOptions, the console lifetime, and the composition that wires di, config, and logging together.",
  "keywords": [
    "hosting",
    "generic-host",
    "ioc",
    "typescript",
    "lifetime",
    "hosted-service"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/hosting"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    },
    "./private/*": {
      "types": "./src/*.ts",
      "bun": "./dist/stage/*.js"
    }
  },
  "files": [
    "dist",
    "!dist/stage"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@rhombus-std/config": "workspace:*",
    "@rhombus-std/config.commandline": "workspace:*",
    "@rhombus-std/config.core": "workspace:*",
    "@rhombus-std/config.env": "workspace:*",
    "@rhombus-std/config.json": "workspace:*",
    "@rhombus-std/di": "workspace:*",
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/diagnostics.core": "workspace:*",
    "@rhombus-std/fileproviders.core": "workspace:*",
    "@rhombus-std/hosting.core": "workspace:*",
    "@rhombus-std/logging": "workspace:*",
    "@rhombus-std/logging.console": "workspace:*",
    "@rhombus-std/logging.core": "workspace:*",
    "@rhombus-std/options": "workspace:*",
    "@rhombus-std/options.augmentations": "workspace:*",
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3"
  },
  "devDependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*",
    "@ttsc/unplugin": "^0.18.1",
    "@types/bun": "^1.3.0",
    "rollup": "^4.61.0",
    "rollup-plugin-dts": "^6.4.1",
    "ttsc": "^0.18.1",
    "typescript": "^5.9.0"
  }
}
