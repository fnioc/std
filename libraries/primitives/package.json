{
  "name": "@rhombus-std/primitives",
  "version": "0.0.0",
  "description": "The change-token primitives ported from ME.Primitives: IChangeToken, ChangeToken.onChange, CancellationChangeToken. A leaf package -- zero dependencies.",
  "keywords": [
    "primitives",
    "change-token",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/primitives"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun x tsc --noEmit -p tsconfig.json && bun build.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
