{
  "name": "@rhombus-std/options.augmentations",
  "version": "0.0.0",
  "description": "The config -> Options bridge for @rhombus-std/options: the addOptions/configure authoring augmentation that binds a configuration section into an IOptions<T> and wires it reactive via the section's reload token.",
  "keywords": [
    "options",
    "configuration",
    "config",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/options.augmentations"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    },
    "./private/*": {
      "types": "./src/*.ts",
      "bun": "./dist/stage/*.js"
    }
  },
  "files": [
    "dist",
    "!dist/stage"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/config.core": "workspace:*",
    "@rhombus-std/options": "workspace:*",
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3"
  },
  "peerDependencies": {
    "@rhombus-std/di.core": "workspace:^"
  },
  "devDependencies": {
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/primitives.transformer": "workspace:*",
    "@ttsc/unplugin": "^0.18.1",
    "ttsc": "^0.18.1",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
