{
  "name": "@rhombus-std/fileproviders.core",
  "version": "0.0.0",
  "description": "Read-only file provider abstractions ported from ME.FileProviders.Abstractions: IFileProvider/IFileInfo/IDirectoryContents plus the null-object helpers (NotFoundFileInfo, NotFoundDirectoryContents, NullFileProvider, NullChangeToken). Depends on @rhombus-std/primitives for the IChangeToken type.",
  "keywords": [
    "fileproviders",
    "filesystem",
    "abstractions",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/fileproviders.core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
