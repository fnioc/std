{
  "name": "@rhombus-std/config.core",
  "version": "0.0.0",
  "description": "Types-only configuration abstractions: the IConfiguration* interfaces and ITryGetResult. Zero runtime; depends on @rhombus-std/primitives for the IChangeToken type only.",
  "keywords": [
    "configuration",
    "config",
    "abstractions",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/config.core"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "//rhombusBuild": "Pure-types package -- ships ZERO runtime (every consumer uses `import type`); the build emits no JS bundle and asserts none appears (§40).",
  "rhombusBuild": {
    "typesOnly": true
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.d.ts"
      }
    }
  }
}
