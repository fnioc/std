{
  "name": "@rhombus-std/config.commandline",
  "version": "0.0.0",
  "description": "Command-line configuration provider for @rhombus-std/config: CommandLineConfigurationSource/Provider + the addCommandLine augmentation.",
  "keywords": [
    "configuration",
    "config",
    "command-line",
    "cli",
    "argv",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/config.commandline"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun x tsc --noEmit -p tsconfig.json && bun build.ts",
    "test": "bun test",
    "lint": "bun x tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@rhombus-std/config.core": "workspace:*"
  },
  "peerDependencies": {
    "@rhombus-std/config": "workspace:^"
  },
  "devDependencies": {
    "@rhombus-std/config": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
