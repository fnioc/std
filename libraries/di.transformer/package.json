{
  "name": "@rhombus-std/di.transformer",
  "version": "10.1.0",
  "description": "The ioc ts-patch transformer: token generation, dependency extraction, registration lowering, and the factory-signature diagnostic.",
  "keywords": [
    "dependency-injection",
    "di",
    "ioc",
    "typescript",
    "ts-patch",
    "transformer",
    "compiler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/di.transformer"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ttsc": "./ttsc.mjs",
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/di.transformer/ttsc"
    }
  },
  "files": [
    "dist",
    "ttsc.mjs"
  ],
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && bun run build.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@rhombus-std/primitives.transformer": "workspace:^",
    "@rhombus-toolkit/func": "3.5.3"
  },
  "peerDependencies": {
    "@rhombus-std/di.core": "workspace:^",
    "typescript": ">=5.2"
  },
  "devDependencies": {
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/primitives.transformer": "workspace:*",
    "ts-patch": "^3.3.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
