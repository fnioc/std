{
  "name": "@rhombus-std/di.transformer",
  "version": "10.1.0",
  "description": "The ioc authoring surface: the type-only declare-module for the token-free registration forms, the inline sugar bodies, and the signatureof primitive. A Go/ttsc descriptor package — the lowering runs in the shared owner binary.",
  "keywords": [
    "dependency-injection",
    "di",
    "ioc",
    "typescript",
    "transformer",
    "compiler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/di.transformer"
  },
  "type": "module",
  "//rhombus.inline": "The type-driven registration sugar's inline publish list. The bodies live in src/inline.ts (authoring-only substitution source, kept out of the barrel + dist); the inline stage side-parses them and substitutes at consumer call sites. The `type` ANCHORS stay @rhombus-std/di.core interfaces (the augmentation targets), while `impl` (ServiceQueryInline / ServiceManifestInline) resolves in THIS package — the authoring-time home of the signatureof primitive those bodies call.",
  "rhombus.inline": {
    "entries": [
      {
        "type": "@rhombus-std/di.core:IServiceQuery",
        "impl": "ServiceQueryInline",
        "member": "isService"
      },
      {
        "type": "@rhombus-std/di.core:IServiceManifestBase",
        "impl": "ServiceManifestInline",
        "member": "add"
      },
      {
        "type": "@rhombus-std/di.core:IServiceManifestBase",
        "impl": "ServiceManifestInline",
        "member": "addFactory"
      },
      {
        "type": "@rhombus-std/di.core:IServiceManifestBase",
        "impl": "ServiceManifestInline",
        "member": "addValue"
      }
    ]
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ttsc": "./ttsc.mjs",
    "./tokens/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/di.transformer/ttsc"
    }
  },
  "files": [
    "dist",
    "ttsc.mjs"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "3.5.3"
  },
  "peerDependencies": {
    "@rhombus-std/di.core": "workspace:^",
    "typescript": ">=5.2"
  },
  "devDependencies": {
    "@rhombus-std/di.core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./ttsc": "./ttsc.mjs"
    }
  }
}
