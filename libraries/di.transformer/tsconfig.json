{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    // Resolve `@rhombus-std/di.core` to its BUILT `.d.ts` (the `built` condition),
    // NOT source. This program carries the `declare module "@rhombus-std/di.core"`
    // augmentation (`./augment.ts`) that merges the tokenless authoring overloads
    // onto `ServiceManifestBase` / `AddBuilder` / `Resolver`. Under those merges
    // di.core's SOURCE cannot co-compile — the concrete `ServiceManifestClass` no
    // longer satisfies its own augmented base interface (TS2416). A real consumer
    // holds the built types and augments on top; the built `.d.ts` is
    // skip-lib-checked, so the augmentation never forces the class to recompile.
    // Mirrors `di.transformer.options` and docs/decisions.md §1/§9.
    "customConditions": ["built"]
  },
  "include": ["src/**/*"]
}
