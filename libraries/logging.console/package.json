{
  "name": "@rhombus-std/logging.console",
  "version": "0.0.0",
  "description": "Console logging provider ported from the reference console-logging package: ConsoleLogger + ConsoleLoggerProvider, the ConsoleFormatter abstraction with the simple/json/systemd built-ins (ANSI colors), formatter/logger options, and an async background queue writer \u2014 against @rhombus-std/logging.core's ILogger/ILoggerProvider contracts.",
  "keywords": [
    "logging",
    "console",
    "logger",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/logging.console"
  },
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./_/*": {
      "source": "./src/*.ts",
      "bun": "./dist/internal/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist",
    "!dist/internal"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/logging": "workspace:*",
    "@rhombus-std/logging.core": "workspace:*",
    "@rhombus-std/options": "workspace:*",
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/type-guards": "^1.3.4"
  },
  "devDependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*",
    "@rhombus-toolkit/func": "3.5.3",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
