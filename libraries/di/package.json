  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@rhombus-std/di.core": "workspace:^"
  },
  "devDependencies": {
    "@rhombus-toolkit/func": "3.5.3"
