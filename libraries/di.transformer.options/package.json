{
  "name": "@rhombus-std/di.transformer.options",
  "version": "0.0.0",
  "description": "A @rhombus-std/di.transformer satellite: the type-only declare-module for the addOptions<T>() sugar. A Go/ttsc descriptor package — the lowering to addOptions(token(IOptions<T>), token(T)) runs in the shared owner binary.",
  "keywords": [
    "options",
    "dependency-injection",
    "di",
    "ioc",
    "typescript",
    "transformer",
    "compiler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/di.transformer.options"
  },
  "type": "module",
  "main": "./dist/bundle/index.js",
  "types": "./dist/bundle/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/bundle/index.d.ts",
      "import": "./dist/bundle/index.js",
      "default": "./dist/bundle/index.js"
    },
    "./ttsc": "./ttsc.mjs",
    "./tokens/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/di.transformer.options/ttsc"
    }
  },
  "files": [
    "dist",
    "ttsc.mjs"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@rhombus-std/di.core": "workspace:^",
    "@rhombus-std/di.transformer": "workspace:^",
    "typescript": ">=5.2"
  },
  "devDependencies": {
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/di.transformer": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/bundle/index.js",
    "types": "./dist/bundle/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/bundle/index.d.ts",
        "import": "./dist/bundle/index.js",
        "default": "./dist/bundle/index.js"
      },
      "./ttsc": "./ttsc.mjs"
    }
  }
}
