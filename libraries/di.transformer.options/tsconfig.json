{
  // This program pulls in di.transformer's `declare module "@rhombus-std/di.core"`
  // augmentation (via the token-machinery import), under which di.core's SOURCE
  // cannot co-compile — the impl class can't satisfy the interface once the
  // authored 0-arg forms merge in. Now that di.core and di.transformer are
  // dist-referenced (§72), their `types` conditions resolve the built,
  // skip-lib-checked `.d.ts`, so no `built` custom condition is needed.
  "extends": "../../tsconfig.lib.json",
  "include": ["src/**/*"]
}
