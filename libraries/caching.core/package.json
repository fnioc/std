{
  "name": "@rhombus-std/caching.core",
  "version": "0.0.0",
  "description": "In-memory cache abstractions ported from ME.Caching.Abstractions: IMemoryCache/ICacheEntry + CacheItemPriority/EvictionReason/PostEvictionDelegate, plus the real-runtime get/set/getOrCreate/tryGetValue convenience wrappers. Depends on @rhombus-std/primitives for the IChangeToken type only.",
  "keywords": [
    "caching",
    "cache",
    "memory-cache",
    "abstractions",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/caching.core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./dist/index.js",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./dist/internal/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist",
    "!dist/internal"
  ],
  "scripts": {
    "build": "bun x tsc --noEmit -p tsconfig.json && bun build.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:*"
  },
  "devDependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*",
    "@ttsc/unplugin": "^0.18.1",
    "ts-patch": "^3.3.0",
    "ttsc": "^0.18.1",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
