{
  "name": "@rhombus-std/caching.core",
  "version": "0.0.0",
  "description": "Cache abstractions ported from ME.Caching.Abstractions: IMemoryCache/ICacheEntry + CacheItemPriority/EvictionReason/PostEvictionDelegate, IDistributedCache/DistributedCacheEntryOptions, the hybrid-cache abstractions (HybridCache, HybridCacheEntryOptions/Flags, IHybridCacheSerializer/IHybridCacheSerializerFactory), plus the real-runtime get/set/getOrCreate/tryGetValue/setString/getString convenience wrappers.",
  "keywords": [
    "caching",
    "cache",
    "memory-cache",
    "abstractions",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/caching.core"
  },
  "type": "module",
  "main": "./dist/bundle/index.js",
  "types": "./dist/bundle/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./dist/bundle/index.js",
      "types": "./dist/bundle/index.d.ts",
      "import": "./dist/bundle/index.js",
      "default": "./dist/bundle/index.js"
    },
    "./tokens/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    },
    "./private/*": {
      "types": "./src/*.ts",
      "bun": "./dist/stage/*.js"
    }
  },
  "files": [
    "dist",
    "!dist/stage"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.ci.json"
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3"
  },
  "devDependencies": {
    "@rhombus-std/primitives.extras": "workspace:*",
    "@ttsc/unplugin": "^0.18.1",
    "ttsc": "^0.18.1",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/bundle/index.js",
    "types": "./dist/bundle/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/bundle/index.d.ts",
        "import": "./dist/bundle/index.js",
        "default": "./dist/bundle/index.js"
      }
    }
  }
}
