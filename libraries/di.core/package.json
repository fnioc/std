{
  "name": "@rhombus-std/di.core",
  "version": "10.1.0",
  "description": "The ioc abstractions substrate: the dependency-signature data format, the slot/token surface + helpers, and the concrete registration builder (ServiceManifest) a library author depends on to author registrations without the di resolution engine. Depends only on the primitives leaf for the augmentation registry.",
  "keywords": [
    "dependency-injection",
    "di",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/di.core"
  },
  "type": "module",
  "sideEffects": true,
  "rhombus.inline": {
    "entries": [
      { "type": "@rhombus-std/di.core:ServiceQuery", "impl": "ServiceQueryInline", "member": "isService" }
    ]
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "di-core-source": "./src/index.ts",
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/internal"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "eslint ."
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@rhombus-std/primitives": "workspace:^"
  },
  "devDependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*",
    "@rhombus-toolkit/func": "3.5.3",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.0"
  }
}
