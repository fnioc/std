{
  "name": "@rhombus-std/logging.configuration",
  "version": "0.0.0",
  "description": "The logging config-binding surface ported from ME.Logging.Configuration: binds LoggerFilterOptions/LoggerFilterRule from an @rhombus-std/config IConfiguration via addConfiguration.",
  "keywords": [
    "logging",
    "configuration",
    "config",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/logging.configuration"
  },
  "type": "module",
  "sideEffects": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun x tsc --noEmit -p tsconfig.json && bun build.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@rhombus-std/config": "workspace:*",
    "@rhombus-std/config.core": "workspace:*",
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/logging": "workspace:*",
    "@rhombus-std/logging.core": "workspace:*",
    "@rhombus-std/options": "workspace:*",
    "@rhombus-std/primitives": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
