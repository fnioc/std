{
  "name": "@rhombus-std/logging.core",
  "version": "0.0.0",
  "description": "Logging abstractions ported from ME.Logging.Abstractions: ILogger/ILoggerFactory/ILoggerProvider/ILoggingBuilder + LogLevel/EventId, plus the real-runtime logInformation/logError/... convenience wrappers. Depends on @rhombus-std/di.core for the ServiceManifest type only.",
  "keywords": [
    "logging",
    "abstractions",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/logging.core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    },
    "./private/*": {
      "types": "./src/*.ts",
      "bun": "./dist/stage/*.js"
    }
  },
  "files": [
    "dist",
    "!dist/stage"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/primitives": "workspace:*"
  },
  "devDependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*",
    "@rhombus-toolkit/func": "3.5.3",
    "@ttsc/unplugin": "^0.18.1",
    "ts-patch": "^3.3.0",
    "ttsc": "^0.18.1",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
