{
  "name": "@rhombus-std/config.transformer",
  "version": "0.0.0",
  "description": "The @rhombus-std/config authoring transformer: rewrites .withType<T>() on a ConfigBuilder into a generated .withSchema({...}) runtime schema literal at compile time. A Go/ttsc descriptor package — the lowering runs in the shared owner binary.",
  "keywords": [
    "configuration",
    "config",
    "ioc",
    "typescript",
    "transformer",
    "compiler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/config.transformer"
  },
  "type": "module",
  "exports": {
    "./ttsc": "./ttsc.mjs"
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/config.transformer/ttsc"
    },
    "stages": ["config"]
  },
  "files": [
    "ttsc.mjs"
  ],
  "dependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*"
  },
  "peerDependencies": {
    "@rhombus-std/config": "workspace:^"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./ttsc": "./ttsc.mjs"
    }
  }
}
