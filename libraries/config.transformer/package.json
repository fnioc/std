{
  "name": "@rhombus-std/config.transformer",
  "version": "0.0.0",
  "description": "The @rhombus-std/config ts-patch transformer: rewrites .withType<T>() on a ConfigurationBuilder into a generated .withSchema({...}) runtime schema literal at compile time.",
  "keywords": [
    "configuration",
    "config",
    "ioc",
    "typescript",
    "ts-patch",
    "transformer",
    "compiler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/config.transformer"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ttsc": "./ttsc.mjs",
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "ttsc": {
    "plugin": {
      "transform": "@rhombus-std/config.transformer/ttsc"
    }
  },
  "files": [
    "dist",
    "ttsc.mjs"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "//rhombusBuild": "The runtime bundle must be @rhombus-std-free: the only \"@rhombus-std/config\" occurrence is the codegen'd import-specifier STRING the transformer emits, never a real ESM import.",
  "rhombusBuild": {
    "forbidImports": [
      "@rhombus-std/config"
    ]
  },
  "peerDependencies": {
    "@rhombus-std/config": "workspace:^",
    "typescript": ">=5.2"
  },
  "dependencies": {
    "@rhombus-toolkit/func": "^3.5.3",
    "@rhombus-toolkit/type-guards": "^1.3.4"
  },
  "devDependencies": {
    "@rhombus-std/config": "workspace:*",
    "@rhombus-std/config.core": "workspace:*",
    "ts-patch": "^3.3.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
