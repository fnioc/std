{
  "name": "@rhombus-std/hosting.core",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@rhombus-std/config.core": "workspace:*",
    "@rhombus-std/di.core": "workspace:*",
    "@rhombus-std/diagnostics.core": "workspace:*",
    "@rhombus-std/fileproviders.core": "workspace:*",
    "@rhombus-std/logging.core": "workspace:*",
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "rollup": "^4.61.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.9.0"
  }
}
