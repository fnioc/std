{
  "name": "@rhombus-std/caching.memory",
  "version": "0.0.0",
  "description": "In-memory cache implementation ported from ME.Caching.Memory: MemoryCache + MemoryCacheOptions/MemoryCacheEntryOptions, the memory-backed MemoryDistributedCache + MemoryDistributedCacheOptions, plus the addMemoryCache/addDistributedMemoryCache authoring augmentations that register IMemoryCache/IDistributedCache on @rhombus-std/di.core's ServiceManifest.",
  "keywords": [
    "caching",
    "cache",
    "memory-cache",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/caching.memory"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./_/*": {
      "source": "./src/*.ts",
      "bun": "./dist/internal/*.js",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist",
    "!dist/internal"
  ],
  "scripts": {
    "build": "bun ../../scripts/build-lib.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/caching.core": "workspace:*",
    "@rhombus-std/logging.core": "workspace:*",
    "@rhombus-std/options": "workspace:*",
    "@rhombus-std/options.augmentations": "workspace:*",
    "@rhombus-std/primitives": "workspace:*",
    "@rhombus-toolkit/func": "^3.5.3",
    "@rhombus-toolkit/type-guards": "^1.3.4"
  },
  "peerDependencies": {
    "@rhombus-std/di.core": "workspace:^"
  },
  "devDependencies": {
    "@rhombus-std/primitives.transformer": "workspace:*",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.0",
    "@rhombus-std/di.core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
