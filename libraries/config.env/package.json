{
  "name": "@rhombus-std/config.env",
  "version": "0.0.0",
  "description": "process.env configuration provider for @rhombus-std/config: EnvironmentVariablesConfigurationSource/Provider + the addEnvironmentVariables augmentation.",
  "keywords": [
    "configuration",
    "config",
    "env",
    "environment-variables",
    "options",
    "ioc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnioc/std.git",
    "directory": "libraries/config.env"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal/*": {
      "source": "./src/*.ts",
      "bun": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun x tsc --noEmit -p tsconfig.json && bun build.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@rhombus-std/config.core": "workspace:*"
  },
  "peerDependencies": {
    "@rhombus-std/config": "workspace:^"
  },
  "devDependencies": {
    "@rhombus-std/config": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
