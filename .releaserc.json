{
  "branches": [
    { "name": "main", "channel": "next" }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/exec", {
      "publishCmd": "bun scripts/publish-libraries.ts --version ${nextRelease.version} --tag next"
    }],
    ["@semantic-release/github", { "prerelease": true }]
  ]
}
