{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    // rootDir is the examples/ parent so the shared source (imported relatively
    // from ../../di.examples.shared/src) compiles in alongside this example's own
    // src — plugin-less source inlining, no bundler. Emit lands at
    // dist/di.examples.with-transformer/src/main.js + dist/di.examples.shared/src/index.js,
    // and the relative import between them is preserved, so `node` runs it standalone.
    "rootDir": "..",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    // The @rhombus-std/di.transformer ts-patch plugin. Active under `tspc` (the build);
    // plain `tsc` (the lint task) ignores it and type-checks the authored form.
    // The plugin's `declare module "@rhombus-std/di.core"` augmentation (the type-driven
    // authoring forms `add<I>(C)`, `.as<"x">()`, tokenless `resolve<I>()`) is
    // pulled into the program by the side-effect `import "@rhombus-std/di.transformer"`
    // at the top of src/main.ts.
    "plugins": [{ "transform": "@rhombus-std/di.transformer", "import": "transform" }],
    // Resolve @rhombus-std/di + @rhombus-std/di.core to their BUILT `.d.ts` (the `built`
    // export condition) rather than source. With the transformer augmentation
    // active, di's SOURCE cannot co-compile: the impl classes can't satisfy the
    // interfaces once the authored 0-arg forms are merged in. A published consumer
    // never compiles di's source — it holds di's built types and applies the
    // augmentation on top of the `@rhombus-std/di.core` interface. Consuming built
    // types here reproduces that representative setup (needs di/di.core built first).
    "customConditions": ["built"]
  },
  "include": ["src/**/*"]
}
