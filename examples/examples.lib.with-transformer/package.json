{
  "name": "@rhombus-std/examples.lib.with-transformer",
  "private": true,
  "version": "0.0.0",
  "description": "Example dependency library authored in the tokenless di dialect and built via the Go/ttsc engine. Its build is its only consumable form \u2014 every exports condition resolves to dist, so raw source never bypasses the transformer lowering.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "lint": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@rhombus-std/examples.contracts": "workspace:*"
  },
  "devDependencies": {
    "@rhombus-std/di": "workspace:*",
    "@rhombus-std/di.transformer": "workspace:*",
    "@rhombus-std/options": "workspace:*",
    "@ttsc/unplugin": "^0.18.1",
    "ttsc": "^0.18.1",
    "typescript": "^5.9.0"
  }
}
