{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // Every sibling package (core/di/transformer) disables composite for its
    // own standalone tsconfig — there are no project references between
    // packages here. Integration additionally reaches one file OUTSIDE its own
    // `test/**/*` tree (di's shared `metadata-shim.ts`, imported by relative
    // path from a couple of test files); composite's "every file must be in
    // the declared file list" check (TS6307) fires the moment an out-of-tree
    // file is reachable, so this must be off here too.
    "composite": false,
    // `@rhombus-std/di.transformer` is listed so its `declare module "@rhombus-std/di.core"`
    // augmentation (the type-only authoring forms `add<I>(C)`, `.as<"x">()`,
    // `resolve<T>()`) enters this program — the sample wiring authors those
    // forms and the transformer lowers them at build time, but plain `tsc` (the
    // lint task) only sees them via this types entry. A `types` array disables
    // automatic @types inclusion, so `bun` is listed explicitly too.
    "types": ["bun", "@rhombus-std/di.transformer"],
    // Integration tests cross a dynamic-module-load boundary (`import()` of the
    // transformer-compiled output) and index token maps heavily. Relaxing
    // `noUncheckedIndexedAccess` here keeps the assertions readable without
    // `!`-littering every token lookup; the production packages keep it on.
    // di and di.core are dist-referenced (§72), so their `types` conditions resolve
    // the built `.d.ts` directly. That matters here because this program pulls in
    // the transformer augmentation (see `types` above), under which di's SOURCE
    // cannot co-compile — the impl classes can't satisfy the interfaces once the
    // authored 0-arg forms are merged in; a real consumer holds di's built types
    // and augments `@rhombus-std/di.core` on top, which the dist `.d.ts` reproduces.
    // No `built` custom condition is needed.
    "noUncheckedIndexedAccess": false
  },
  "include": ["test/**/*"]
}
