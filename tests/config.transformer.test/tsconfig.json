{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // Every sibling package (config/config.core/config.transformer) disables
    // composite for its own standalone tsconfig — there are no project
    // references between packages here. Keeping it off here matches that and
    // sidesteps composite's "every file must be in the declared file list"
    // check (TS6307), which the white-box `./_/*` seam into the
    // transformer's src would otherwise trip.
    "composite": false,
    // The transformer package is listed so its published types enter this
    // program alongside `bun`. A `types` array disables automatic @types
    // inclusion, so `bun` (used by every `bun:test` spec) is listed explicitly.
    "types": ["bun", "@rhombus-std/config.transformer"],
    // The e2e spec crosses a dynamic-module-load boundary (it shells out to the
    // real `tspc` and reads the emitted output) and indexes emitted-text maps
    // heavily. Relaxing `noUncheckedIndexedAccess` here keeps the assertions
    // readable without `!`-littering every lookup; the production package keeps
    // it on.
    // config.core is dist-referenced (its `types` resolves the rolled `.d.ts`);
    // config itself is still src-referenced (its subpath augmentations are not yet
    // flipped, §74), so it resolves to source. Neither needs a `built` custom
    // condition — the `built` export condition has been retired.
    "noUncheckedIndexedAccess": false
  },
  "include": ["test/**/*"]
}
