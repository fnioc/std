{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // No project references between packages; the harness reaches library dirs
    // by path, so composite's TS6307 would fire — keep it off.
    "composite": false,
    // A `types` array disables automatic @types inclusion, so `bun` (used by the
    // spec) is listed explicitly. The sample sources are compiled by tspc in a
    // temp project, not by this lint program, so no transformer types are needed
    // here.
    "types": ["bun"],
    // The spec crosses a dynamic-module-load boundary and reads emitted text;
    // relax unchecked-index so assertions read cleanly.
    "noUncheckedIndexedAccess": false
  },
  "include": ["test/**/*"]
}
